# Distriblog Go Docker Image
# Multi-stage build for smaller final image

# Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /build

# Install build dependencies
RUN apk add --no-cache git

# Copy go mod files
COPY golang/go.mod golang/go.sum* ./
RUN go mod download

# Copy web client for embedding
COPY web/ ./web/

# Copy source code
COPY golang/*.go ./

# Build
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o distriblog .

# Runtime stage
FROM alpine:3.19

RUN apk --no-cache add ca-certificates && \
    adduser -D -s /bin/sh distriblog

WORKDIR /app

COPY --from=builder /build/distriblog .

# Create data directory
RUN mkdir -p /data && chown distriblog:distriblog /data

USER distriblog

ENV PORT=4557

EXPOSE 4557

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost:4557/api/identities || exit 1

CMD ["./distriblog"]
